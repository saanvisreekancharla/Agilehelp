✅ 7. JENKINS PIPELINE (Jenkinsfile)

Create file Jenkinsfile:

pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/YOUR_USERNAME/YOUR_REPO.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }
    }
}
✅ 8. JENKINS STEPS
Open Jenkins
